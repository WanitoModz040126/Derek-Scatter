# Copy this file to .env for local development.
# On Railway, set these under Project → Variables instead.

PORT=3000

# Long random string — used to sign login session cookies.
SESSION_SECRET=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

# Seeded admin account (created automatically on first run if it doesn't exist yet).
